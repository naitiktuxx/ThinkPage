{
  "manifest_version": 2,
  "name": "ThinkPage Bridge",
  "version": "1.3.1",
  "description": "Minimal bridge to pass browser history and handle focus for ThinkPage.",
  "permissions": [
    "history",
    "tabs",
    "cookies",
    "https://thinkpage.vercel.app/*",
    "file://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://thinkpage.vercel.app/*",
        "file://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
